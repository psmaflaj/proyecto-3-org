CHIP Computer {
    IN reset;

    PARTS:
    ROM32K(address=pc, out=instruction);

    CPU(
        inM=memOut,
        instruction=instruction,
        reset=reset,
        outM=cpuOutM,
        writeM=cpuWriteM,
        addressM=cpuAddressM,
        pc=pc
    );

    Memory(
        in=cpuOutM,
        load=cpuWriteM,
        address=cpuAddressM,
        out=memOut
    );
}
